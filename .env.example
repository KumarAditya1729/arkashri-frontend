# Arkashri frontend environment template.
# Copy to .env.local for local development. Do not commit real secrets.

# Server-side backend URL used by Next.js route handlers.
API_URL=http://localhost:8001

# Public fallback backend URL. Set this in Vercel if API_URL is not used.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8001

# Public frontend URL for server-side self-calls to /api/proxy.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tenant header forwarded to the backend.
NEXT_PUBLIC_API_TENANT=default_tenant

# WebSocket base URL for audit collaboration streams.
NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws
